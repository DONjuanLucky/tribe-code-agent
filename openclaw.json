{
  "agent": {
    "model": "anthropic/claude-sonnet-4-5",
    "name": "Tribe"
  },
  "agents": {
    "defaults": {
      "workspace": "/Users/pro/TRIBECODEOPENCLAW/workspace"
    }
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 60,
    "model": "anthropic/claude-haiku-4-5"
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "allowFrom": ["YOUR_PERSONAL_WHATSAPP_NUMBER"],
      "dmPolicy": "pairing"
    },
    "telegram": {
      "enabled": false,
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN"
    }
  },
  "gateway": {
    "port": 18789,
    "bind": "loopback"
  }
}
